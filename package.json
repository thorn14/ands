{
  "name": "ands-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Agent-Native Design System (ANDS) — portable harness for agentic AI consumption",
  "scripts": {
    "build": "pnpm -r --sequential build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "clean": "pnpm -r --parallel exec -- rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.1.0"
}
