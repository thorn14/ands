{
  "name": "@ands/vpat",
  "version": "0.1.0",
  "description": "VPAT 2.5 WCAG Edition report generator from ANDS a11y results",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
