{
  "name": "@ands/contracts",
  "version": "0.1.0",
  "description": "Core portability contracts: branded types, Result<T,E>, assertNever, Zod helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
