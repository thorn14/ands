{
  "name": "@ands/foundation-primitives",
  "version": "0.1.0",
  "description": "Portable primitive contracts (Button, Input) with mandatory a11y at type level",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@ands/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
