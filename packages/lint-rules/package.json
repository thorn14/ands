{
  "name": "@ands/lint-rules",
  "version": "0.1.0",
  "description": "Reference plugin: lint rules for ANDS governance (no-raw-token-value, no-deprecated-prop, prop-naming-consistency, no-hardcoded-string, pii-exposure)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@ands/contracts": "workspace:*",
    "oxc-parser": "^0.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.5"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidthorn/ands.git",
    "directory": "packages/lint-rules"
  }
}
