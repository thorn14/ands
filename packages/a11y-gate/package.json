{
  "name": "@ands/a11y-gate",
  "version": "0.1.0",
  "description": "Reference plugin: a11y testing gate for ANDS governance (OXC, axe-core, lighthouse)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@ands/contracts": "workspace:*",
    "oxc-parser": "^0.60.0",
    "aria-query": "^5.3.2"
  },
  "peerDependencies": {
    "@axe-core/playwright": "^4.0.0",
    "playwright": "^1.40.0",
    "lighthouse": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "@axe-core/playwright": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "lighthouse": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.5"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/davidthorn/ands.git",
    "directory": "packages/a11y-gate"
  }
}
